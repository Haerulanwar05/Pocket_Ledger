{
  "functions": {
    "*.php": {
      "runtime": "vercel-php@0.6.0"
    },
    "actions/*.php": {
      "runtime": "vercel-php@0.6.0"
    }
  },
  "routes": [
    {
      "src": "/actions/(.*)",
      "dest": "/actions/$1"
    },
    {
      "src": "/(.*\\.php)",
      "dest": "/$1"
    },
    {
      "src": "/",
      "dest": "/index.php"
    }
  ]
}
